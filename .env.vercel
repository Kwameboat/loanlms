####################################################################
# Big Cash LMS — Vercel + Supabase Environment Variables
# Copy into Vercel → Settings → Environment Variables
####################################################################

APP_NAME="Big Cash"
APP_ENV=production
APP_KEY=                                    # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://bigcash-lms.vercel.app          # Your Vercel / custom domain

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── Database: Supabase PostgreSQL ──────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Use "Session pooler" (port 6543) for Vercel serverless
# Use "Direct connection" (port 5432) for running migrations locally
#
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

DB_CONNECTION=pgsql
DB_HOST=aws-0-us-east-1.pooler.supabase.com   # Replace with your region
DB_PORT=6543                                    # 6543 = session pooler (Vercel)
DB_DATABASE=postgres
DB_USERNAME=postgres.your_project_ref          # From Supabase connection string
DB_PASSWORD=your_supabase_db_password
DB_SSLMODE=require

# Supabase direct URL (for migrations only — use locally, not on Vercel)
# DB_HOST=db.your_project_ref.supabase.co
# DB_PORT=5432
# DB_USERNAME=postgres

# ─── Serverless-safe drivers ────────────────────────────────────────────────
CACHE_DRIVER=array
SESSION_DRIVER=cookie
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=r2

# ─── Cloudflare R2 (Persistent file storage) ────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=bigcash-uploads
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://pub-HASH.r2.dev

# ─── Mail (Resend — free 3,000/month) ────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_your_resend_api_key
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@bigcash.com
MAIL_FROM_NAME="Big Cash Finance"

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxx
PAYSTACK_PAYMENT_URL=https://api.paystack.co
PAYSTACK_MERCHANT_EMAIL=merchant@bigcash.com
PAYSTACK_MODE=live

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
AI_ENABLED=true
AI_MODEL=gpt-4o-mini

# ─── SMS ─────────────────────────────────────────────────────────────────────
SMS_PROVIDER=arkesel
SMS_API_KEY=your_arkesel_key
SMS_SENDER_ID=BigCash

# ─── Push Notifications (VAPID) ──────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@bigcash.com

# ─── Company ─────────────────────────────────────────────────────────────────
COMPANY_NAME="Big Cash Finance"
COMPANY_CURRENCY=GHS
COMPANY_CURRENCY_SYMBOL=₵
COMPANY_TIMEZONE=Africa/Accra
COMPANY_PHONE=+233000000000
COMPANY_EMAIL=info@bigcash.com

# ─── Cron security ───────────────────────────────────────────────────────────
CRON_SECRET=generate_a_long_random_string_here
