APP_NAME="Big Cash"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# Database — Supabase PostgreSQL (default)
# For local dev: use port 5432 direct connection
# For Vercel: use port 6543 session pooler
DB_CONNECTION=pgsql
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your_supabase_password
DB_SSLMODE=require

# For local MySQL (cPanel hosting) — uncomment and swap DB_CONNECTION=mysql
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=bigcash_db
# DB_USERNAME=db_user
# DB_PASSWORD=db_password

CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_your_resend_key
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@bigcash.com
MAIL_FROM_NAME="${APP_NAME}"

PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
PAYSTACK_PAYMENT_URL=https://api.paystack.co
PAYSTACK_MERCHANT_EMAIL=merchant@yourdomain.com
PAYSTACK_MODE=test

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_ENABLED=true
AI_MODEL=gpt-4o-mini

SMS_PROVIDER=log
SMS_API_KEY=
SMS_SENDER_ID=BigCash

COMPANY_NAME="Big Cash Finance"
COMPANY_CURRENCY=GHS
COMPANY_CURRENCY_SYMBOL=₵
COMPANY_TIMEZONE=Africa/Accra
COMPANY_DATE_FORMAT=d/m/Y
COMPANY_PHONE=+233000000000
COMPANY_EMAIL=info@bigcash.com

TWO_FACTOR_ENABLED=false
MAX_FILE_SIZE=5120
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=10

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@yourdomain.com

CRON_SECRET=change_this_to_a_random_secret

# Vercel + Cloudflare R2
# FILESYSTEM_DISK=r2
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=bigcash-uploads
# CLOUDFLARE_R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# CLOUDFLARE_R2_PUBLIC_URL=https://pub-HASH.r2.dev
