    "share_target": {
        "action": "/portal/share",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "document",
                    "accept": [
                        "application/pdf",
                        "image/jpeg",
                        "image/png"
                    ]
                }
            ]
        }
    },
    "prefer_related_applications": false
