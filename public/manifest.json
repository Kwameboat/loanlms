            "icons": [
                {
                    "src": "/icons/icon-96x96.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Apply for Loan",
            "short_name": "Apply",
            "url": "/portal/loans/apply?src=shortcut",
            "icons": [
                {
                    "src": "/icons/icon-96x96.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Payment History",
            "short_name": "Payments",
